{
  "name": "n8n-nodes-comtele-gateway",
  "version": "1.0.0",
  "description": "N8N community node for Comtele Gateway API integration",
  "author": "Comtele",
  "license": "MIT",
  "homepage": "https://github.com/comtele/n8n-nodes-comtele-gateway",
  "repository": {
    "type": "git",
    "url": "https://github.com/comtele/n8n-nodes-comtele-gateway.git"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "comtele",
    "gateway",
    "rcs",
    "sms",
    "messaging"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "n8n": {
    "nodes": [
      "dist/nodes/ComteleGateway/ComteleGateway.node.js"
    ],
    "credentials": [
      "dist/credentials/ComteleGatewayApi.credentials.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "n8n-core": "^0.191.0",
    "n8n-workflow": "^0.191.0",
    "prettier": "^2.8.8",
    "typescript": "^4.9.0"
  }
}