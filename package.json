{
  "name": "n8n-nodes-comtele-gateway",
  "version": "1.0.5",
  "description": "Send SMS and RCS messages via Comtele Gateway",
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "author": {
    "name": "Comtele",
    "email": "suporte@comtele.com.br",
    "url": "https://www.comtele.com.br"
  },
  "license": "MIT",
  "homepage": "https://github.com/comtele/n8n-nodes-comtele-gateway",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comtele/n8n-nodes-comtele-gateway.git"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "comtele",
    "gateway",
    "rcs",
    "sms",
    "messaging"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "nodes/ComteleGateway/ComteleGateway.node.json",
    "LICENSE",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/ComteleGateway/ComteleGateway.node.js"
    ],
    "credentials": [
      "dist/credentials/ComteleGatewayApi.credentials.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "n8n-core": "^2.5.0",
    "n8n-workflow": "^2.5.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
